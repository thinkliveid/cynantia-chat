# ---- Model (OpenAI / OpenAI-compatible) — dipakai semua agent ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
AGENT_MODEL=openai/gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Persistensi (Postgres) ----
DATABASE_URL=postgresql+psycopg://cynantia:cynantia@postgres:5432/cynantia

# ---- Registry specialist (base URL dilihat dari orchestrator) ----
FAQ_AGENT_URL=http://faq:8002
MATH_AGENT_URL=http://math:8003
FAQ_PORT=8002
MATH_PORT=8003

# ---- Webhook backend ----
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# ---- Google Chat ----
GOOGLE_SERVICE_ACCOUNT_FILE=/secrets/service-account.json
# Project NUMBER GCP untuk verifikasi token dari Google Chat. Kosong = dev.
CHAT_AUDIENCE=
